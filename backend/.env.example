# Copy to backend/.env and fill in real values. Do not commit .env.

MISTRAL_API_KEY=
GROQ_API_KEY=
SECRET_KEY=change-me-generate-a-random-32-plus-char-string-here
ENVIRONMENT=development
DEBUG=false
LOG_LEVEL=INFO
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=aae_db
MONGO_SERVER_SELECTION_TIMEOUT_MS=10000
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
STORAGE_PROVIDER=local
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.1
OPENAI_MAX_TOKENS=4096
OPENAI_TIMEOUT_SECONDS=120
OPENAI_MAX_RETRIES=3
MAX_UPLOAD_SIZE_MB=50
MAX_PAGES_PER_SCRIPT=40
JWT_ACCESS_TOKEN_EXPIRES_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRES_DAYS=7
OCR_TEST_DELAY_SECONDS=8
OPENAI_MODEL_VISION=gpt-4o
USE_CELERY_REDIS=true
EVALUATION_BATCH_SIZE=5
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_MODEL_VISION=meta-llama/llama-4-scout-17b-16e-instruct
ALLOW_MOCK_DB_FALLBACK=true
