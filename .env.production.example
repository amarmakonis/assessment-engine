# Copy to .env and fill values before deployment
# NEVER commit .env to git

# Required - use: openssl rand -hex 32
SECRET_KEY=your-32-char-hex-secret-key-here

# MongoDB Atlas (free tier: https://cloud.mongodb.com)
# Include database name in URI, e.g. .../aae_db?retryWrites=...
MONGO_URI=mongodb+srv://USER:PASSWORD@cluster.xxxxx.mongodb.net/aae_db?retryWrites=true&w=majority
MONGO_DB_NAME=aae_db

# Redis (optional here; docker-compose.production.yml sets these for backend/celery)
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# OpenAI (required for OCR + evaluation)
OPENAI_API_KEY=sk-...

# JWT (use same as SECRET_KEY if empty)
JWT_SECRET_KEY=

# Production settings
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=INFO
