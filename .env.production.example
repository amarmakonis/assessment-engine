# Copy to .env (at project root) and fill values before deployment
# NEVER commit .env to git

# Required - use: openssl rand -hex 32
SECRET_KEY=your-32-char-hex-secret-key-here

# MongoDB Atlas (free tier: https://cloud.mongodb.com)
# Include database name in URI, e.g. .../aae_db?retryWrites=...
MONGO_URI=mongodb+srv://USER:PASSWORD@cluster.xxxxx.mongodb.net/aae_db?retryWrites=true&w=majority
MONGO_DB_NAME=aae_db

# Production uses Redis + Celery for async OCR and evaluation.
USE_CELERY_REDIS=true
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
# CELERY_WORKER_CONCURRENCY=4

# OpenAI (required for OCR + evaluation)
OPENAI_API_KEY=

# JWT (leave empty to use SECRET_KEY)
JWT_SECRET_KEY=

# Production
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=INFO

# Storage: local for EC2 (no S3). Create dir and chown to app user.
STORAGE_PROVIDER=local
LOCAL_STORAGE_PATH=/var/lib/aae/uploads
