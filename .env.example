# ═══════════════════════════════════════════════════════
# Agentic Assessment Engine — Environment Configuration
# Copy to .env and fill in production values
# ═══════════════════════════════════════════════════════

# ── Core ──────────────────────────────────────────────
SECRET_KEY=change-me-generate-a-random-32-plus-char-string-here
ENVIRONMENT=development
DEBUG=false
LOG_LEVEL=INFO

# ── MongoDB ───────────────────────────────────────────
MONGO_URI=mongodb://mongo:27017
MONGO_DB_NAME=aae_db
# Optional: with MongoDB Atlas, increase timeouts in Celery workers to avoid OCR task timeouts (ms).
# MONGO_SERVER_SELECTION_TIMEOUT_MS=60000
# MONGO_SOCKET_TIMEOUT_MS=60000

# ── Redis / Celery (optional) ─────────────────────────
# Set USE_CELERY_REDIS=false for sync-only mode (no Celery/Redis)
USE_CELERY_REDIS=false
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
# CELERY_WORKER_CONCURRENCY=4   # parallel tasks per worker; increase for higher throughput

# ── Object Storage ────────────────────────────────────
# gridfs = MongoDB (default); local = filesystem; s3 = S3/MinIO
STORAGE_PROVIDER=gridfs
# For S3/MinIO:
# STORAGE_PROVIDER=s3
# S3_BUCKET_NAME=aae-uploads
# S3_ENDPOINT_URL=http://minio:9000
# S3_ACCESS_KEY=minioadmin
# S3_SECRET_KEY=minioadmin
# S3_REGION=us-east-1

# ── OpenAI (Powers EVERYTHING: OCR + Agents + Evaluation) ─
# Get your key from https://platform.openai.com/api-keys — do not commit real keys
OPENAI_API_KEY=

# Default gpt-4o-mini for faster pipeline; set to gpt-4o for higher accuracy
OPENAI_MODEL=gpt-4o-mini
# Vision OCR: gpt-4o recommended for handwritten text (best accuracy)
# OPENAI_MODEL_VISION=gpt-4o
OPENAI_TEMPERATURE=0.1
OPENAI_MAX_TOKENS=4096
OPENAI_TIMEOUT_SECONDS=120
OPENAI_MAX_RETRIES=3
# OPENAI_ORGANIZATION=org-xxx  (optional)

# ── Upload Limits ─────────────────────────────────────
MAX_UPLOAD_SIZE_MB=50
MAX_PAGES_PER_SCRIPT=40

# ── OCR (answer papers: speed vs quality) ───────────────
# OCR_TEST_MAX_CONCURRENT=2   # default; 2–3 for faster pipeline; use 1 if 429 rate limits
# OCR_TEST_DELAY_SECONDS=2   # default; 1–2 for speed; increase to 5+ for free-tier OpenAI
# OCR_DPI=120   # default; increase to 150 for denser scripts
# OCR_PAGE_SOFT_TIME_LIMIT=300
# OCR_PAGE_TIME_LIMIT=330

# ── Segmentation & evaluation speed (optional) ───────────
# OPENAI_MODEL_SEGMENTATION=gpt-4o-mini  # default; leave unset to use OPENAI_MODEL
# OPENAI_SEGMENTATION_MAX_TOKENS=16384   # default; keep high so long answers (e.g. essays) are not cut off
# SEGMENTATION_MAX_OCR_CHARS=0   # default; 0 = full OCR so full answers captured; set 120000 only if accepting tail truncation
# SEGMENTATION_MAX_QUESTION_TEXT_CHARS=300   # truncate each question in prompt (0 = no truncation)
# SEGMENTATION_SOFT_TIME_LIMIT=300
# SEGMENTATION_TIME_LIMIT=330
# OPENAI_EVALUATION_MAX_TOKENS=1024   # default; increase to 2048 if feedback is truncated
# EVALUATION_MAX_WORKERS=5   # parallel questions per script (sync mode); 3–8; reduce if 429
# USE_MERGED_AGENTS=true   # default; scoring+consistency and feedback+explainability merged → 3 LLM calls per question

# ── JWT Auth ──────────────────────────────────────────
JWT_SECRET_KEY=
JWT_ACCESS_TOKEN_EXPIRES_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRES_DAYS=7
