# ═══════════════════════════════════════════════════════
# Agentic Assessment Engine — Environment Configuration
# Copy to .env and fill in production values
# ═══════════════════════════════════════════════════════

# ── Core ──────────────────────────────────────────────
SECRET_KEY=change-me-generate-a-random-32-plus-char-string-here
ENVIRONMENT=development
DEBUG=false
LOG_LEVEL=INFO

# ── MongoDB ───────────────────────────────────────────
MONGO_URI=mongodb://mongo:27017
MONGO_DB_NAME=aae_db
# Optional: with MongoDB Atlas, increase timeouts in Celery workers to avoid OCR task timeouts (ms).
# MONGO_SERVER_SELECTION_TIMEOUT_MS=60000
# MONGO_SOCKET_TIMEOUT_MS=60000

# ── Redis ─────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ── Object Storage ────────────────────────────────────
# gridfs = MongoDB (default); local = filesystem; s3 = S3/MinIO
STORAGE_PROVIDER=gridfs
# For S3/MinIO:
# STORAGE_PROVIDER=s3
# S3_BUCKET_NAME=aae-uploads
# S3_ENDPOINT_URL=http://minio:9000
# S3_ACCESS_KEY=minioadmin
# S3_SECRET_KEY=minioadmin
# S3_REGION=us-east-1

# ── OpenAI (Powers EVERYTHING: OCR + Agents + Evaluation) ─
OPENAI_API_KEY=sk-your-openai-api-key-here
# Default gpt-4o-mini for faster pipeline; set to gpt-4o for higher accuracy
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.1
OPENAI_MAX_TOKENS=4096
OPENAI_TIMEOUT_SECONDS=120
OPENAI_MAX_RETRIES=3
# OPENAI_ORGANIZATION=org-xxx  (optional)

# ── Upload Limits ─────────────────────────────────────
MAX_UPLOAD_SIZE_MB=50
MAX_PAGES_PER_SCRIPT=40

# ── OCR (answer papers: speed vs quality) ───────────────
# OCR_DPI=120   # default; increase to 150 for denser scripts
# OCR_PAGE_SOFT_TIME_LIMIT=300
# OCR_PAGE_TIME_LIMIT=330

# ── Segmentation & evaluation speed (optional) ───────────
# OPENAI_MODEL_SEGMENTATION=gpt-4o-mini  # default; leave unset to use OPENAI_MODEL
# OPENAI_SEGMENTATION_MAX_TOKENS=8192   # default; lower only if you accept possible truncation
# SEGMENTATION_MAX_OCR_CHARS=0   # default = full OCR; set e.g. 80000 only if you accept truncating long scripts
# SEGMENTATION_MAX_QUESTION_TEXT_CHARS=500   # truncate each question in prompt (0 = no truncation)
# SEGMENTATION_SOFT_TIME_LIMIT=300
# SEGMENTATION_TIME_LIMIT=330
# OPENAI_EVALUATION_MAX_TOKENS=1024   # default; increase to 2048 if feedback is truncated

# ── JWT Auth ──────────────────────────────────────────
JWT_SECRET_KEY=
JWT_ACCESS_TOKEN_EXPIRES_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRES_DAYS=7
